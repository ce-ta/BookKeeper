<%= stylesheet_link_tag '/assets/session_new.css', media: 'all', 'data-turbolinks-track': 'reload' %>

<% if flash[:alert] %>
<div class="form-error">
  <%= flash[:alert] %>
</div>
<% end %>

<% if flash[:success] %>
<div class="form-success">
  <%= flash[:success] %>
</div>
<% end %>

<div class="form_heading">ログイン</div>

<div class="form-container">
<%= form_with url: "/login", method: "post" do |f| %>
  <p>メールアドレス</p>
  <%= f.email_field :email, value: @input_email %>
  <p>パスワード</p>
  <%= f.password_field :password %>
  <%= f.submit "ログイン" %>
<% end %>
</div>