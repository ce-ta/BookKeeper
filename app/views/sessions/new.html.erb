<%= stylesheet_link_tag '/assets/user_login_form.css', media: 'all', 'data-turbolinks-track': 'reload' %>


<div class="form-error">
  <%= flash[:login_error] %>
</div>

<div class="form_heading">ログイン</div>

<div class="form-container">
<%= form_with url: "/login", method: "post" do |f| %>
  <p>メールアドレス</p>
  <%= f.email_field :email, value: @input_email %>
  <p>パスワード</p>
  <%= f.password_field :password %>
  <%= f.submit "ログイン" %>
<% end %>
</div>